</div>

<?php
$engineLogic = <<<JS
var oldHash = "";
var vastaukset = [];

var formStub = '<form class="tarkistus-lomake"><input type="text" class="vastaus-kentta" /> <button type="submit" class="btn btn-primary btn-tarkista">Tarkista</button></form>';

function smoothScrollTo(elementId) {
    const element = document.getElementById(elementId);
    if (!element) return;
    const offset = 100;
    const bodyRect = document.body.getBoundingClientRect().top;
    const elementRect = element.getBoundingClientRect().top;
    const elementPosition = elementRect - bodyRect;
    const offsetPosition = elementPosition - offset;

    window.scrollTo({
        top: offsetPosition,
        behavior: 'smooth'
    });
}

function tarkistaKysymys(inputElement, logicType = 'blur') {
    if (!inputElement) return;
    const form = inputElement.closest('form');
    if (!form) return;

    const allForms = Array.from(document.querySelectorAll('.tarkistus-lomake'));
    const index = allForms.indexOf(form);
    const val = inputElement.value.trim();
    const div = form.parentElement;

    if (index === -1 || !vastaukset[index]) return;

    const isCorrect = vastaukset[index].test(val);

    if (isCorrect) {
        div.className = "oikea";
        const btn = form.querySelector('button');
        if (btn) btn.disabled = true;
        if (logicType === 'input' || logicType === 'submit') {
            inputElement.blur();
        }
    } else {
        const btn = form.querySelector('button');
        if (btn) btn.disabled = false;

        if (logicType === 'blur') {
            div.className = (val.length === 0) ? "boksi" : "vaara";
        } else if (val.length === 0) {
            div.className = "boksi";
        }
    }
}

function kont() {
    oldHash = window.location.hash;
    const hash = window.location.hash.substring(1);

    if (!hash) {
        naytaIndeksi();
    } else {
        let foundTask = false;
        otsikot.forEach(g => {
            g.lomakkeet.forEach(l => {
                if (l.llid === hash) {
                    naytaLomake(l);
                    foundTask = true;
                }
            });
        });

        if (!foundTask) {
            const isLandmark = otsikot.some(g => g.slug === hash);
            if (isLandmark) {
                naytaIndeksi();
                smoothScrollTo(hash);
            } else {
                naytaIndeksi();
            }
        }
    }
}

function naytaLomake(lomake) {
    document.getElementById("otsikko").innerHTML = lomake.otsikko;
    document.getElementById("ohje").style.display = "block";

    document.querySelectorAll(".palaa-alkuun").forEach(btn => {
        btn.style.display = "inline-block";
    });

    const kp = document.getElementById("koepaikka");
    kp.innerHTML = "";
    vastaukset = [];

    lomake.kysymykset.forEach(k => {
        const div = document.createElement('div');
        div.className = "boksi";
        div.innerHTML = "<p><strong>" + k.kysymys + "</strong></p>" + formStub;
        vastaukset.push(k.vastaus);
        kp.appendChild(div);
    });
    window.scrollTo(0, 0);
}

function naytaIndeksi() {
    document.getElementById("otsikko").innerHTML = "Mobiilitehtävät";
    document.getElementById("ohje").style.display = "none";

    document.querySelectorAll(".palaa-alkuun").forEach(btn => {
        btn.style.display = "none";
    });

    const kp = document.getElementById("koepaikka");
    kp.innerHTML = "";

    otsikot.forEach(group => {
        const div = document.createElement('div');
        div.className = "tehtava-osio infobox";
        const landmarkId = group.slug || group.otsikko.toLowerCase().replace(/\s+/g, '-');

        let html = "<h2 id='" + landmarkId + "'>" + group.otsikko + "</h2><ul class='tehtava-lista'>";

        group.lomakkeet.forEach(l => {
            html += "<li>" +
                        "<a href='#" + l.llid + "'>" +
                            "<i class='fa fa-chevron-right' aria-hidden='true'></i>" +
                            "<span>" + l.lomake + "</span>" +
                        "</a>" +
                    "</li>";
        });
        html += "</ul>";
        div.innerHTML = html;
        kp.appendChild(div);
    });

    const hash = window.location.hash.substring(1);
    if (hash) {
        setTimeout(() => { smoothScrollTo(hash); }, 50);
    }
}

const confirmModalEl = document.getElementById('confirmReturnModal');
const confirmModal = confirmModalEl ? new bootstrap.Modal(confirmModalEl) : null;

document.getElementById('confirmExitBtn')?.addEventListener('click', () => {
    window.location.hash = "";
    confirmModal?.hide();
});

document.addEventListener('input', e => {
    if (e.target.classList.contains('vastaus-kentta')) {
        const form = e.target.closest('form');
        const allForms = Array.from(document.querySelectorAll('.tarkistus-lomake'));
        const index = allForms.indexOf(form);
        const regex = vastaukset[index];
        const patternString = regex.toString();
        if (patternString.includes('.+') || patternString.includes('.*')) {
            return;
        }
        tarkistaKysymys(e.target, 'input');
    }
});

document.addEventListener('focusout', e => {
    if (e.target.classList.contains('vastaus-kentta')) {
        tarkistaKysymys(e.target, 'blur');
    }
});

document.addEventListener('submit', e => {
    if (e.target.classList.contains('tarkistus-lomake')) {
        e.preventDefault();
        tarkistaKysymys(e.target.querySelector('input'), 'blur');
    }
});

window.addEventListener("hashchange", () => {
    if (oldHash !== window.location.hash) kont();
});

// Vahvistusdialogi jos johonkin kenttään on syötetty tekstiä ja osa kentistä on kesken.
document.addEventListener('click', e => {
    const palaaBtn = e.target.closest('.palaa-alkuun');
    if (palaaBtn) {
        const hasUnfinished = Array.from(document.querySelectorAll('.vastaus-kentta')).some(el => {
            const isCorrect = el.closest('.oikea') !== null;
            const hasText = el.value.trim() !== "";
            return hasText && !isCorrect;
        });
        const hasWrong = document.querySelectorAll('.vaara').length > 0;
        if (hasUnfinished || hasWrong) {
            confirmModal?.show();
        } else {
            window.location.hash = "";
        }
    }
});

kont();
JS;
echo $this->assetManager()->outputInlineScriptString($engineLogic);


?>
