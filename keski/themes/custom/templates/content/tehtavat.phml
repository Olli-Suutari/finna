<?php
$this->headTitle('Mobiilitehtävät');

$tehtavatPath = __DIR__ . '/tehtavat.json';
$huomaaPath = __DIR__ . '/huomaaTehtavat.json';
$tehtavatData = file_exists($tehtavatPath) ? json_decode(file_get_contents($tehtavatPath), true) : [];
$huomaaData = file_exists($huomaaPath) ? json_decode(file_get_contents($huomaaPath), true) : [];
$kaikkiTehtavat = array_merge($tehtavatData, $huomaaData);
$jsonData = json_encode($kaikkiTehtavat);

$initScript = "
    var otsikotRaw = $jsonData;
    var otsikot = otsikotRaw.map(function(group) {
        if (group.lomakkeet) {
            group.lomakkeet.forEach(function(lomake) {
                if (lomake.kysymykset) {
                    lomake.kysymykset.forEach(function(q) {
                        if (typeof q.vastaus === 'string') {
                            if (q.vastaus.indexOf('^') === -1) {
                                q.vastaus = new RegExp('^\\\\s*(' + q.vastaus + ')\\\\s*$', 'i');
                            } else {
                                q.vastaus = new RegExp(q.vastaus, 'i');
                            }
                        }
                    });
                }
            });
        }
        return group;
    });
";
echo $this->assetManager()->outputInlineScriptString($initScript);
?>

